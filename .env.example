# ---------------------------------------------------------------------------
# Notion-Google-Workspace-Sync configuration (placeholders only — never commit
# real secrets). Copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# --- Notion ---------------------------------------------------------------
# Internal integration token (https://www.notion.so/my-integrations)
NOTION_API_TOKEN=secret_xxx
# Verification token returned when you subscribe the webhook endpoint.
NOTION_WEBHOOK_SECRET=
# The Notion user id of the integration/bot. Edits attributed to this user are
# treated as our own writes and skipped (echo suppression, step 2).
SYNC_BOT_NOTION_USER_ID=
# Comma-separated Notion ids that bound the crawl. Defaults to the three core
# databases + Mission Control + Library when left blank.
NOTION_ROOT_IDS=

# --- Google (OAuth user credentials; personal gmail) ----------------------
# Contents of the OAuth client JSON (installed-app / web client). Stored as a
# single-line JSON string.
GOOGLE_CREDENTIALS_JSON=
# Offline refresh token obtained via scripts/bootstrap.py consent flow.
GOOGLE_OAUTH_REFRESH_TOKEN=
# Drive folder id that roots the entire mirror ("Notion Mirror").
GOOGLE_DRIVE_MIRROR_FOLDER_ID=
# Spreadsheet id of the "_Notion Index" sheet (created by bootstrap).
GOOGLE_INDEX_SHEET_ID=

# --- Service ---------------------------------------------------------------
LEDGER_DB_PATH=/data/ledger.db
LOG_LEVEL=INFO
# Polling cadences (seconds).
NOTION_POLL_SECONDS=180
GOOGLE_POLL_SECONDS=120
# Seconds an inflight echo-suppression marker stays valid.
INFLIGHT_TTL_SECONDS=300
# Grace period before a tombstoned pair is purged.
TOMBSTONE_GRACE_SECONDS=86400
