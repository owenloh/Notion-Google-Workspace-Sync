# ---------------------------------------------------------------------------
# Notion-Google-Workspace-Sync configuration (placeholders only — never commit
# real secrets). Copy to `.env` and fill in.
#
# Model: Notion -> Google is a one-way READ reflection (Docs). Writes happen via
# a Google Tasks command inbox that this service RELAYS to your existing
# "Alistair Skills API". This service's own Notion access is read-only.
# ---------------------------------------------------------------------------

# --- Notion (READ-ONLY mirror) --------------------------------------------
# Internal integration token, read-only scope is sufficient.
NOTION_API_TOKEN=secret_xxx
# Comma-separated Notion ids that bound the crawl. Defaults to the three core
# databases + Mission Control + Library when left blank.
NOTION_ROOT_IDS=
# Optional: enable the Notion webhook for near-instant reflection of edits made
# by hand in Notion. Off by default (the poll layers cover it).
ENABLE_NOTION_WEBHOOK=false
NOTION_WEBHOOK_SECRET=

# --- Google (OAuth user credentials; personal gmail) ----------------------
# Contents of the OAuth client JSON (installed-app / web client), single line.
GOOGLE_CREDENTIALS_JSON=
# Offline refresh token from scripts/bootstrap.py (scopes include Tasks).
GOOGLE_OAUTH_REFRESH_TOKEN=
# Drive folder id that roots the mirror ("Notion Mirror").
GOOGLE_DRIVE_MIRROR_FOLDER_ID=
# Spreadsheet id of the optional "_Notion Index" sheet (desktop view).
GOOGLE_INDEX_SHEET_ID=
# Google Tasks list used as the command inbox.
COMMAND_TASKLIST_NAME=Notion Commands

# --- Relay to the Alistair Skills API (the WRITE path) --------------------
RELAY_API_BASE_URL=https://web-production-2144c.up.railway.app
RELAY_API_KEY=
# Allowlisted API paths the relay may call (anything else is rejected).
RELAY_ALLOWED_PATHS=/api/notion/create-pages,/api/notion/update-page,/api/notion/create-comment
# Path used when a command task carries a bare body (no explicit path).
RELAY_DEFAULT_PATH=/api/notion/create-pages

# --- Service ---------------------------------------------------------------
LEDGER_DB_PATH=/data/ledger.db
LOG_LEVEL=INFO
# Command inbox poll (Google Tasks has no push).
COMMAND_POLL_SECONDS=30
# Notion delta poll (spine + loose pages).
NOTION_POLL_SECONDS=180
# Full re-crawl cadence (deep child-page edits + heals drift + regenerates Docs).
FULL_SYNC_SECONDS=1800
TOMBSTONE_GRACE_SECONDS=86400
# Secret required for POST /admin/full-sync and POST /command.
# curl -X POST "https://<host>/admin/full-sync?key=$ADMIN_API_KEY"
ADMIN_API_KEY=
